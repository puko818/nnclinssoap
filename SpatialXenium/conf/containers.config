/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Container configuration for nnclinssoap pipeline
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Supports both Docker and Singularity/Apptainer containers
    
    Docker images: Built with docker/build_all_images.sh (Docker mode)
    Singularity images: Built with docker/build_all_images.sh (Apptainer/Singularity mode)
    
    Usage:
    - Docker: nextflow run -profile docker
      (automatically uses: nnclinssoap/scrnaseq-spatialxenium:4.5.2)
    - Singularity: nextflow run -profile singularity
      (automatically uses: ../containers/scrnaseq-spatialxenium_4.5.2.sif)
      
    Note: The profile determines which container format is used. This config provides
    paths for Singularity. For Docker, override with docker profile in nextflow.config.
----------------------------------------------------------------------------------------
*/

params {
    // Container configuration
    // For Singularity: path to .sif files (default: relative to SpatialXenium/ directory)
    container_base_path = "../containers"
    container_version   = "4.5.2"
    
    // Allow override via command line:
    // --container_base_path /custom/path/to/containers
}

process {
    // Default container for all spatial xenium processes
    // Singularity format (default): ../containers/scrnaseq-spatialxenium_4.5.2.sif
    // Docker format: Override in docker profile (see nextflow.config)
    container = "${params.container_base_path}/scrnaseq-spatialxenium_${params.container_version}.sif"
    
    // Specific process overrides
    withName: 'SEURAT_XENIUM' {
        container = "${params.container_base_path}/scrnaseq-spatialxenium_${params.container_version}.sif"
    }
    
    withName: 'LABEL_TRANSFER' {
        container = "${params.container_base_path}/scrnaseq-spatialxenium_${params.container_version}.sif"
    }
    
    withName: 'PLOT_FEATURES' {
        container = "${params.container_base_path}/scrnaseq-spatialxenium_${params.container_version}.sif"
    }
    
    withName: 'QC_REPORT' {
        container = "${params.container_base_path}/qc-report_1.0.sif"
    }
}
