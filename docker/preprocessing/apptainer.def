Bootstrap: docker-daemon
From: nnclinssoap/scrnaseq-preprocessing:4.5.2

%labels
    maintainer zemw@novonordisk.com
    description R environment for scRNA-seq preprocessing: Seurat, SoupX, scDblFinder, harmony
    version 4.5.2

%environment
    export LC_ALL=C
    export PATH=/usr/local/bin:$PATH
    export R_LIBS_USER=/usr/local/lib/R/site-library

%runscript
    exec R "$@"

%help
    Preprocessing environment (R 4.5.2, Bioconductor 3.22)
    Key packages: Seurat 5.1, SoupX, scDblFinder, harmony, DropletUtils, whirl
    Built from Docker image nnclinssoap/scrnaseq-preprocessing:4.5.2
