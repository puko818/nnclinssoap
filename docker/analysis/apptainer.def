Bootstrap: docker-daemon
From: nnclinssoap/scrnaseq-analysis:4.5.2

%labels
    maintainer zemw@novonordisk.com
    description R environment for scRNA-seq analysis: Azimuth, SingleR, edgeR, Signac
    version 4.5.2

%environment
    export LC_ALL=C
    export PATH=/usr/local/bin:$PATH
    export R_LIBS_USER=/usr/local/lib/R/site-library

%runscript
    exec R "$@"

%help
    Analysis environment (R 4.5.2, Bioconductor 3.22)
    Key packages: Azimuth, SingleR, celldex, edgeR, limma, DESeq2, Signac
    Built from Docker image nnclinssoap/scrnaseq-analysis:4.5.2
