Bootstrap: docker-daemon
From: nnclinssoap/scrnaseq-base:4.5.2

# Thin wrapper — converts the already-built Docker base image to .sif. The Dockerfile
# (docker/base/Dockerfile) is the single source of truth for package content; there is
# no %post here. Requires the Docker image to exist
# locally first (build it via docker/build_single.sh base).
# This only has formal purpose now - the user can run apptainer directly on the docker images for preprocessing/analysis and spatialxenium



%labels
    maintainer zemw@novonordisk.com
    description Base R 4.5.2 / Bioc 3.22 environment with Seurat — binary-package build
    version 4.5.2

%environment
    export LC_ALL=C
    export PATH=/usr/local/bin:$PATH
    export R_LIBS_USER=/usr/local/lib/R/site-library

%runscript
    exec R "$@"

%help
    Base R 4.5.2 environment (Bioconductor 3.22) with Seurat and common dependencies.
    Built from Docker image nnclinssoap/scrnaseq-base:4.5.2 (single source of truth).
    Used as the base for scrnaseq-preprocessing, scrnaseq-analysis, and scrnaseq-spatialxenium.
